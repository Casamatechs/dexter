#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

source "${plugin_dir}/lib/utils.bash"

command -v go >/dev/null 2>&1 || fail "Go is required. Install via mise: mise use -g go@1.26.1"
command -v cc >/dev/null 2>&1 || fail "A C compiler is required for SQLite. On macOS: brew install sqlite"
